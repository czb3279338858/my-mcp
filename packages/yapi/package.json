{
  "name": "yapi-mcp-plus",
  "version": "1.0.0",
  "description": "Yapi MCP Plus - 基于 Yapi MCP 的增强扩展，让 AI 助手更高效地访问 Yapi API 管理平台",
  "type": "module",
  "bin": {
    "yapi-mcp-plus": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "yapi",
    "api",
    "model-context-protocol",
    "ai",
    "api-management"
  ],
  "license": "MIT",
  "scripts": {
    "nvm":"nvm use 24.15.0 && timeout /T 1 /NOBREAK",
    "build": "npm run nvm && tsc",
    "dev": "npm run nvm && tsc --watch",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector --config ./inspector.json",
    "release": "npm run build && npm version patch && npm publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
